pluginManagement {
    repositories {
        mavenCentral()
        gradlePluginPortal()
        maven { url = "https://maven.fabricmc.net/" }
        maven { url = "https://maven.kikugie.dev/snapshots" }
        maven { url = "https://maven.kikugie.dev/releases" }
    }
}

plugins {
    id 'dev.kikugie.stonecutter' version '0.9.1'
}

stonecutter {
    create(rootProject) {
        versions('1.21.4', '1.21.5', '1.21.8', '1.21.9', '1.21.10', '1.21.11', '26.1')
        vcsVersion = '1.21.10'
    }
}

rootProject.name = 'coffeeproxy'
